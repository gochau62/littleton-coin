CREATE TABLE CLRCUSSEGT(
 CSFRDT  DECIMAL(8, 0) WITH DEFAULT NOT NULL,       -- From Date  20260614
 CSTODT  DECIMAL(8, 0) WITH DEFAULT NOT NULL,       -- To Date    20260620
 CSCUST# DECIMAL(9, 0) WITH DEFAULT NOT NULL,       -- Customer #
 CSSEGC  CHAR(10) CCSID 37 WITH DEFAULT NOT NULL    -- Segment Code (A00)
 )
RCDFMT CSSEGTR;

LABEL ON CLRCUSSEGT(
 CSFRDT  TEXT IS 'From Date',
 CSTODT  TEXT IS 'To Date',
 CSCUST# TEXT IS 'Customer #',
 CSSEGC  TEXT IS 'Segment Code');

 LABEL ON CLRCUSSEGT(
 CSFRDT  IS 'Week From           Date',
 CSTODT  IS 'Week To             Date',
 CSCUST# IS 'Customer            Number',
 CSSEGC  IS 'Segment             Code');

 LABEL ON TABLE CLRCUSSEGT IS 'Clario Customer Segment Table';
