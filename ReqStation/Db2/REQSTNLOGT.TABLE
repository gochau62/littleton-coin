CREATE TABLE REQSTNLOGT(
 ACSEQ#  DECIMAL(11, 0) GENERATED ALWAYS AS IDENTITY
         (START WITH 1, INCREMENT BY 1) NOT NULL,      -- Sequence
 ACUSER  VARCHAR(10) CCSID 37 WITH DEFAULT NOT NULL,   -- User Profile
 ACDATE  DECIMAL(8, 0) WITH DEFAULT NOT NULL,          -- Date 20260720
 ACTIME  DECIMAL(6, 0) WITH DEFAULT NOT NULL,          -- Time HHMMSS
 ACACTN  VARCHAR(20) CCSID 37 WITH DEFAULT NOT NULL,   -- Action Code
 ACREQ#  DECIMAL(9, 0) WITH DEFAULT NOT NULL,          -- Requisition (0=n/a)
 PRIMARY KEY (ACSEQ#))
 RCDFMT REQSTNLOGR;

LABEL ON TABLE REQSTNLOGT IS 'Requisition Activity Log';
